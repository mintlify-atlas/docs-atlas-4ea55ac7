  "keyFeatures": [
    "Real-time dashboards with live data updates and interactive charts",
    "Session replay with privacy controls (cookieless, mask inputs/text)",
    "Funnels and cohort analysis for conversion tracking",
    "A/B testing with variant breakdowns",
    "Smart notifications for events and funnels (Slack, Discord)",
    "User profiles and session history",
    "Multi-platform SDKs: Web, Next.js, React, Vue, Astro, Nuxt, Express, React Native, Swift (iOS), Kotlin (Android), Rust, Ruby",
    "Privacy-first and GDPR-compliant cookieless tracking",
    "Self-hosting support via Docker Compose",
    "REST API for event ingestion, data export, and project management"
  ],
  "publicApiSurface": [
    "POST /track — Ingest events (track, identify, increment, decrement, replay)",
    "GET /track/device-id — Retrieve device and session IDs",
    "POST /event — Post a raw event",
    "POST /profile — Update a user profile",
    "POST /profile/increment — Increment a profile property",
    "POST /profile/decrement — Decrement a profile property",
    "GET /export/events — Export raw events",
    "GET /export/charts — Export chart data",
    "GET /insights/:projectId/metrics — Get website metrics overview",
    "GET /insights/:projectId/live — Get live visitor count",
    "GET /insights/:projectId/pages — Get page views and top pages",
    "GET /manage/projects — List projects",
    "POST /manage/projects — Create a project",
    "PATCH /manage/projects/:id — Update a project",
    "DELETE /manage/projects/:id — Delete a project",
    "GET /manage/clients — List API clients",
    "POST /manage/clients — Create an API client",
    "OpenPanel (JS SDK) — track(), identify(), screenView(), increment(), decrement(), revenue(), setGlobalProperties(), ready(), flush(), clear()",
    "OpenPanel (Web SDK) — trackScreenViews(), trackOutgoingLinks(), trackAttributes(), pendingRevenue(), flushRevenue(), sessionReplay options",
    "OpenPanelComponent (Next.js) — React component for script injection",
    "useOpenPanel() (Next.js) — React hook exposing all tracking methods"
  ]
